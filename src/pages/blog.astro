    </nav>
    <button id="menu-btn" class="lg:hidden p-2 text-[#F8F0CB] hover:text-[#E7CE50]" aria-label="Open menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>
  <div id="mobile-menu" class="hidden lg:hidden bg-[#342F12] px-4 pb-4">
    <a href="/D1912" class="block py-2 text-sm text-[#F8F0CB] hover:text-[#E7CE50]">Home</a>
    <a href="/D1912/about-us" class="block py-2 text-sm text-[#F8F0CB] hover:text-[#E7CE50]">About Me</a>
