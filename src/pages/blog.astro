    <h2 class="text-2xl font-bold text-[#453E18] mb-4">Ready to Start Learning?</h2>
    <p class="text-[#453E18] mb-6">Call us today to book your first driving lesson in Glasgow.</p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="tel:07397040400" class="inline-flex items-center gap-2 bg-[#453E18] text-white font-bold px-6 py-3 rounded-lg hover:bg-[#342F12] transition-colors">📞 07397 040400</a>
      <a href="/D1912/contact-us" class="inline-flex items-center gap-2 bg-white text-[#453E18] font-bold px-6 py-3 rounded-lg hover:bg-[#FDFBF1] transition-colors">Get in Touch</a>
    </div>
  </div>
</section>

