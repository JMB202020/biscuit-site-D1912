        <img src="/D1912/images/logo-accelerate-s.png" alt="Accelerate Driving Tuition" width="180" height="60" class="h-10 w-auto mb-4 brightness-0 invert opacity-80" loading="lazy" />
        <p class="text-sm text-[#F8F0CB]/70 mb-3">84 Aros Dr, Glasgow</p>
        <a href="tel:07397040400" class="text-[#E7CE50] font-semibold hover:underline">07397 040400</a>
        <p class="text-xs text-[#F8F0CB]/50 mt-4">Established 1998</p>
      </div>
      <div>
        <h4 class="font-bold text-[#E7CE50] mb-3 text-sm uppercase tracking-wider">Main</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/D1912" class="text-[#F8F0CB]/80 hover:text-[#E7CE50]">Home</a></li>
          <li><a href="/D1912/about-us" class="text-[#F8F0CB]/80 hover:text-[#E7CE50]">About Me</a></li>
          <li><a href="/D1912/lessons-cost-glasgow" class="text-[#F8F0CB]/80 hover:text-[#E7CE50]">Lessons &amp; Cost</a></li>
