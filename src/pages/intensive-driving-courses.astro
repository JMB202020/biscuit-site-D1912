      <div>
        <h4 class="font-bold text-[#E7CE50] mb-3 text-sm uppercase tracking-wider">Lessons</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/D1912/pass-plus-glasgow" class="text-[#F8F0CB]/80 hover:text-[#E7CE50]">Pass Plus</a></li>
          <li><a href="/D1912/intensive-driving-courses" class="text-[#F8F0CB]/80 hover:text-[#E7CE50]">Intensive Courses</a></li>
          <li><a href="/D1912/show-me-tell-me" class="text-[#F8F0CB]/80 hover:text-[#E7CE50]">Show Me/Tell Me</a></li>
