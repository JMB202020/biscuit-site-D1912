          <li><a href="/D1912/driving-lessons-glasgow-west-end" class="text-[#F8F0CB]/80 hover:text-[#E7CE50]">Glasgow West End</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-bold text-[#E7CE50] mb-3 text-sm uppercase tracking-wider">Passes</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/D1912/thomas-cunningham" class="text-[#F8F0CB]/80 hover:text-[#E7CE50]">Thomas Cunningham</a></li>
          <li><a href="/D1912/kirsty-stone" class="text-[#F8F0CB]/80 hover:text-[#E7CE50]">Kirsty Stone</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-[#F8F0CB]/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-[#F8F0CB]/50">&copy; 2024 Accelerate Driving Tuition. All rights reserved. 84 Aros Dr, Glasgow.</p>
      <img src="/D1912/images/logos-acc.png" alt="Accreditation logos" width="200" height="43" class="h-8 w-auto opacity-60 brightness-0 invert" loading="lazy" />
    </div>
  </div>
</footer>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn.addEventListener('click', () => menu.classList.toggle('hidden'));
</script>
</body>
</html>
