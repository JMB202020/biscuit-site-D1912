        <li><a href="/D1912/glasgow-areas" class="hover:text-[#E7CE50] transition-colors">Areas</a></li>
        <li><a href="/D1912/contact-us" class="hover:text-[#E7CE50] transition-colors">Contact Us</a></li>
        <li><a href="/D1912/thomas-cunningham" class="hover:text-[#E7CE50] transition-colors">Thomas Cunningham</a></li>
        <li><a href="/D1912/kirsty-stone" class="hover:text-[#E7CE50] transition-colors">Kirsty Stone</a></li>
      </ul>
    </div>
    <div>
      <h3 class="font-bold text-[#E7CE50] mb-4 uppercase text-xs tracking-wider">Services</h3>
      <ul class="space-y-2 text-sm text-white/80">
        <li><a href="/D1912/pass-plus-glasgow" class="hover:text-[#E7CE50] transition-colors">Pass Plus</a></li>
        <li><a href="/D1912/intensive-driving-courses" class="hover:text-[#E7CE50] transition-colors">Intensive Courses</a></li>
        <li><a href="/D1912/show-me-tell-me" class="hover:text-[#E7CE50] transition-colors">Show Me / Tell Me</a></li>
        <li><a href="/D1912/driving-instructor-jobs-glasgow" class="hover:text-[#E7CE50] transition-colors">Instructor Jobs</a></li>
      </ul>
    </div>
    <div>
      <h3 class="font-bold text-[#E7CE50] mb-4 uppercase text-xs tracking-wider">Areas</h3>
      <ul class="space-y-2 text-sm text-white/80">
        <li><a href="/D1912/driving-lessons-glasgow" class="hover:text-[#E7CE50] transition-colors">Glasgow</a></li>
        <li><a href="/D1912/driving-lessons-east-kilbride" class="hover:text-[#E7CE50] transition-colors">East Kilbride</a></li>
        <li><a href="/D1912/driving-lessons-hamilton" class="hover:text-[#E7CE50] transition-colors">Hamilton</a></li>
        <li><a href="/D1912/driving-lessons-paisley" class="hover:text-[#E7CE50] transition-colors">Paisley</a></li>
        <li><a href="/D1912/driving-lessons-glasgow-north" class="hover:text-[#E7CE50] transition-colors">Glasgow North</a></li>
        <li><a href="/D1912/driving-lessons-glasgow-southside" class="hover:text-[#E7CE50] transition-colors">Glasgow South Side</a></li>
        <li><a href="/D1912/driving-lessons-glasgow-east-end" class="hover:text-[#E7CE50] transition-colors">Glasgow East End</a></li>
        <li><a href="/D1912/driving-lessons-glasgow-west-end" class="hover:text-[#E7CE50] transition-colors">Glasgow West End</a></li>
      </ul>
    </div>
  </div>
  <div class="max-w-6xl mx-auto mt-8 pt-6 border-t border-white/10 text-center text-white/50 text-sm">
    <p>&copy; {new Date().getFullYear()} Accelerate Driving Tuition &bull; 84 Aros Dr, Glasgow &bull; 07397 040400</p>
  </div>
</footer>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
</body>
</html>
