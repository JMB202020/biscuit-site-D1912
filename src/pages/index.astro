        <div class="flex items-center gap-4 mb-3">
          <img src="/D1912/images/img-0613-190x190.jpg" alt="Thomas Cunningham" width="60" height="60" class="rounded-full object-cover w-14 h-14" loading="lazy" />
          <div>
            <p class="font-bold text-[#423F33]">Thomas Cunningham</p>
            <span class="text-xs bg-[#E7CE50] text-[#423F33] px-2 py-0.5 rounded-full font-bold">PASSED</span>
          </div>
        </div>
