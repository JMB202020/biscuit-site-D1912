      </a>
      <a href="/D1912/kirsty-stone" class="bg-white rounded-xl border border-[#F8F0CB] shadow-sm p-6 hover:shadow-md hover:border-[#E7CE50] transition-all block">
        <div class="flex items-center gap-4 mb-3">
          <img src="/D1912/images/img-0499-190x190.jpg" alt="Kirsty Stone" width="60" height="60" class="rounded-full object-cover w-14 h-14" loading="lazy" />
          <div>
            <p class="font-bold text-[#423F33]">Kirsty Stone</p>
            <span class="text-xs bg-[#E7CE50] text-[#423F33] px-2 py-0.5 rounded-full font-bold">PASSED</span>
