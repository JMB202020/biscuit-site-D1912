        <span class="text-white text-xs">Driving Tuition</span>
      </div>
    </a>
    <nav class="hidden md:flex items-center gap-1 text-sm font-semibold">
      <a href="/D1912" class="text-[#E7CE50] px-3 py-2 rounded">Home</a>
      <a href="/D1912/about-us" class="text-white hover:text-[#E7CE50] px-3 py-2 rounded transition-colors">About Me</a>
