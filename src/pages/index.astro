          <div class="w-14 h-14 rounded-full bg-[#E7CE50] flex items-center justify-center text-[#423F33] font-bold text-xl flex-shrink-0">M</div>
          <div>
            <p class="font-bold text-[#423F33]">Mark McPherson</p>
            <span class="text-xs bg-[#E7CE50] text-[#423F33] px-2 py-0.5 rounded-full font-bold">PASSED</span>
          </div>
